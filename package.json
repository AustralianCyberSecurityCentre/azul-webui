    "@types/upng-js": "2.1.5",
    "@zip.js/zip.js": "2.8.26",
    "angular-eslint": "22.0.0",
    "eslint": "10.6.0",
    "openapi-typescript": "7.13.0",
    "postcss": "8.5.16",
    "prettier": "3.9.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.1",
    "typescript": "^6.0.0",
    "typescript-eslint": "8.62.1",
    "upng-js": "2.1.0"
  }
