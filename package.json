{
  "name": "azul-webui",
  "version": "12.0.0",
  "scripts": {
    "ng": "ng",
    "local": "ng serve --proxy-config proxy.conf.json",
    "local-keycloak": "ng serve --c=oauth --proxy-config proxy.conf.json",
    "remote-local": "ng serve --c=remote --proxy-config proxy.conf.json",
    "remote-dev": "ng serve --c=remote --proxy-config src/assets/alt-remote/proxy.dev.json",
    "remote": "ng serve --c=remote --proxy-config src/assets/alt-remote/proxy.qa.json",
    "build": "ng build --configuration production",
    "lint": "ng lint"
  },
  "private": true,
  "packageManager": "npm@11.17.0",
  "//": "Override required because ngx-monaco-editor-v2 is slow at updating",
  "overrides": {
    "ngx-monaco-editor-v2": {
      "@angular/common": "^22.0.0",
      "@angular/core": "^22.0.0",
      "monaco-editor": "^0.55.1"
    },
    "@ngrx/router-store": {
      "@angular/common": "^22.0.0",
      "@angular/core": "^22.0.0",
      "@angular/router": "^22.0.0"
    },
    "ngx-toastr": {
      "@angular/common": "^22.0.0",
      "@angular/core": "^22.0.0"
    },
    "openapi-typescript": {
      "typescript": "^6.0.0"
    }
  },
  "dependencies": {
    "@angular-slider/ngx-slider": "^22.0.0",
    "@angular/cdk": "^22.0.2",
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/router": "^22.0.2",
    "@angular/service-worker": "^22.0.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fortawesome/angular-fontawesome": "^5.0.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@ngrx/router-store": "^21.1.1",
    "@ngrx/store": "^21.1.1",
    "@nozbe/microfuzz": "^1.0.0",
    "@tailwindcss/postcss": "^4.3.1",
    "angular-auth-oidc-client": "^21.0.2",
    "angular-split": "^20.0.0",
    "axios": "1.18.1",
    "axios-cache-interceptor": "1.12.0",
    "d3": "^7.9.0",
    "dagre-d3-es": "^7.0.14",
    "date-fns": "^4.4.0",
    "monaco-editor": "^0.55.1",
    "monaco-types": "^0.1.2",
    "ngx-monaco-editor-v2": "^21.1.4",
    "ngx-toastr": "^20.0.5",
    "rxjs": "^7.8.2",
    "showdown": "^2.1.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "22.0.0",
    "@angular/build": "22.0.5",
    "@angular/cli": "22.0.5",
    "@angular/compiler-cli": "22.0.5",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@schematics/angular": "22.0.5",
    "@tailwindcss/forms": "0.5.11",
    "@types/d3": "7.4.3",
    "@types/node": "26.0.1",
